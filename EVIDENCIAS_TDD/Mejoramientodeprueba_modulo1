const CONFIG_DEFECTO = Object.freeze({
    COSTO_DELIVERY: 5.00,
    PRODUCTO_RECOMPENSA: 'cafe'
});

const normalizar = (texto) => 
    String(texto || '').trim().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");

// Diccionario desacoplado de Reglas de Negocio
const ReglasNegocio = {
    aplicarDelivery: (total, _, opciones, config) => 
        opciones.conDelivery ? total + config.COSTO_DELIVERY : total,

    aplicarCafeGratis: (total, productos, opciones, config) => {
        if (!opciones.cafeGratis) return total;
        const cafe = productos.find(p => normalizar(p?.nombre) === normalizar(config.PRODUCTO_RECOMPENSA));
        return cafe ? total - (Number(cafe.precio) || 0) : total;
    }
};

class MotorPrecios {
    constructor(config = CONFIG_DEFECTO) {
        this.config = Object.freeze({ ...config });
        this.pipeline = [ReglasNegocio.aplicarDelivery, ReglasNegocio.aplicarCafeGratis];
    }

    ejecutar(productos = [], opciones = {}) {
        if (!Array.isArray(productos)) return 0;

        const subtotal = productos.reduce((acc, p) => acc + (Number(p?.precio) || 0), 0);

        return this.pipeline.reduce(
            (totalActual, regla) => regla(totalActual, productos, opciones, this.config), 
            subtotal
        );
    }
}

// Interfaz de compatibilidad exacta con tus 38 tests existentes
const motor = new MotorPrecios();
function calcularTotal(productos, opciones) {
    return motor.ejecutar(productos, opciones);
}

# URL de la API del Backend (en desarrollo es http://localhost:3001/api)
VITE_API_URL=http://localhost:3001/api

# URL del Servidor de Socket.io (en desarrollo es http://localhost:3001)
VITE_SOCKET_URL=http://localhost:3001

# ============================================================
# IngenioSnack Backend — Variables de Entorno (Ejemplo)
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env real a GitHub ni a ningún repositorio de control de versiones.

# Base de datos Supabase PostgreSQL
# Obtén esto desde: Supabase → Settings → Database → Connection String (Transaction Pooler, puerto 6543)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa (sin pooler) - Supabase → Settings → Database → Direct connection (puerto 5432)
DIRECT_URL="postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres"

# JWT Secret - Genera uno fuerte en producción: openssl rand -base64 64
JWT_SECRET="ingeniosnack_jwt_secret_muy_seguro_2026"

# Puerto del servidor
PORT=3001

# Entorno (development | production)
NODE_ENV=development

# URL del frontend (para CORS en producción)
# En desarrollo: http://localhost:5173
# En producción: https://ingeniosnack.onrender.com (o tu URL de Render)
FRONTEND_URL=http://localhost:5173

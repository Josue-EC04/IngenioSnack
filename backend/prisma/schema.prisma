generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  nombre            String
  correo            String   @unique
  codigo_estudiante String?  @unique
  password_hash     String
  rol               String   @default("estudiante") // "estudiante" | "admin"
  puntos_fidelidad  Int      @default(0)
  created_at        DateTime @default(now())

  pedidos           Pedido[]
  cupones           CuponFidelidad[]
  historial_puntos  HistorialPuntos[]

  @@map("users")
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  categoria   String   // "sandwiches" | "bebidas" | "snacks"
  imagen_url  String?
  stock       Int      @default(0)
  activo      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  detalles    DetallePedido[]

  @@map("productos")
}

model Pedido {
  id             Int      @id @default(autoincrement())
  numero_pedido  String   @unique
  user_id        Int
  estado         String   @default("recibido") // "recibido" | "preparando" | "listo" | "entregado"
  total          Float
  metodo_pago    String   @default("contra_entrega")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user           User            @relation(fields: [user_id], references: [id])
  detalles       DetallePedido[]
  historial_puntos HistorialPuntos[]

  @@map("pedidos")
}

model DetallePedido {
  id              Int     @id @default(autoincrement())
  pedido_id       Int
  producto_id     Int
  cantidad        Int
  precio_unitario Float
  subtotal        Float

  pedido          Pedido   @relation(fields: [pedido_id], references: [id])
  producto        Producto @relation(fields: [producto_id], references: [id])

  @@map("detalle_pedidos")
}

model CuponFidelidad {
  id               Int       @id @default(autoincrement())
  user_id          Int
  codigo           String    @unique
  tipo             String    @default("cafe_americano")
  canjeado         Boolean   @default(false)
  fecha_generacion DateTime  @default(now())
  fecha_canje      DateTime?

  user             User @relation(fields: [user_id], references: [id])

  @@map("cupones_fidelidad")
}

model HistorialPuntos {
  id            Int      @id @default(autoincrement())
  user_id       Int
  pedido_id     Int?
  puntos_ganados Int
  descripcion   String
  created_at    DateTime @default(now())

  user          User    @relation(fields: [user_id], references: [id])
  pedido        Pedido? @relation(fields: [pedido_id], references: [id])

  @@map("historial_puntos")
}
